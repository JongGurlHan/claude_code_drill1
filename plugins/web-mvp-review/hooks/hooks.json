{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/pre-commit-check.js"],
            "if": "Bash(git *)",
            "timeout": 180,
            "statusMessage": "Pre-commit: running lint/build/test…"
          }
        ]
      }
    ]
  }
}
